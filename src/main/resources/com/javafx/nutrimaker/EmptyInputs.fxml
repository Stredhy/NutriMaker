<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="147.0" prefWidth="305.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.javafx.nutrimaker.EmptyInputsController">
   <children>
      <HBox alignment="CENTER" prefHeight="55.0" prefWidth="305.0">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" text="No pueden existir entradas vacias">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <Button layoutX="120.0" layoutY="89.0" mnemonicParsing="false" onAction="#closeWindow" style="-fx-background-color: #40c15e;" text="Aceptar" textFill="WHITE">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <font>
            <Font size="14.0" />
         </font>
         <effect>
            <DropShadow>
               <color>
                  <Color opacity="0.4751908481121063" />
               </color>
            </DropShadow>
         </effect>
      </Button>
   </children>
</AnchorPane>
